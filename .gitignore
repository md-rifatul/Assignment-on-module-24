## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bin/
obj/

# Visual Studio
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/

# Logs
*.log

# Database files
*.mdf
*.ldf

# Entity Framework
Migrations/

# OS files
.DS_Store
Thumbs.db

# IIS Express
IISExpress/

# Publish folder
publish/

# npm
node_modules/

# Environment variables
.env

# AppSettings (optional if you don’t want to push connection string)
appsettings.Development.json