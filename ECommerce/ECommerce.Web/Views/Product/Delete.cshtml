@model Product

@{
    ViewData["Title"] = "Delete Product";
}

<h1>Delete Product</h1>

<h3>Are you sure you want to delete this?</h3>

<dl class="row">
    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Id)</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Name)</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Price)</dt>
    <dd class="col-sm-10">@Model.Price.ToString("0.00")</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Stock)</dt>
    <dd class="col-sm-10">@Model.Stock</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.CategoryId)</dt>
    <dd class="col-sm-10">@Model.CategoryId</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

